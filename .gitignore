# ===================================
# MovieStream - Complete .gitignore
# ===================================

# ===== ENVIRONMENT & SECRETS =====
# CRITICAL: Never commit sensitive data
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
backend/.env.local
backend/.env.production

# Specific environment files that should never be committed
*/.env
**/.env
.env.*
!.env.example
!.env.sample

# API Keys and Secrets
*.key
*.pem
*.p12
*.pfx
secrets/
config/secrets/

# ===== NODE.JS & NPM =====
# Dependencies
node_modules/
backend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Package manager files
package-lock.json
yarn.lock
pnpm-lock.yaml

# ===== BUILD & DISTRIBUTION =====
# Frontend build outputs
dist/
dist-ssr/
build/
out/

# Backend build outputs
backend/dist/
backend/build/

# ===== LOGS & DEBUGGING =====
# Log files
logs/
*.log
*.log.*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# ===== EDITOR & IDE =====
# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# ===== OPERATING SYSTEM =====
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.tmp
*.temp
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ===== TEMPORARY & CACHE =====
# Temporary folders
tmp/
temp/
.tmp/
.temp/

# Cache directories
.cache/
.parcel-cache/
.next/
.nuxt/
.vuepress/dist/

# ESLint cache
.eslintcache

# Stylelint cache
.stylelintcache

# ===== DATABASE & UPLOADS =====
# Database files (if using local DB)
*.db
*.sqlite
*.sqlite3

# Upload directories
uploads/
backend/uploads/
public/uploads/
static/uploads/

# ===== TESTING =====
# Test coverage
coverage/
.nyc_output/

# Jest
jest_*

# ===== DEPLOYMENT & CLOUD =====
# Vercel
.vercel/

# Netlify
.netlify/

# AWS
.aws/

# Docker
.dockerignore
Dockerfile.prod

# ===== MISC FILES =====
# Backup files
*.bak
*.backup
*.old

# Archive files
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# ===== LOCAL DEVELOPMENT =====
# Local configuration
local.json
local.config.js

# Development databases
dev.db
development.db

# Test files (if not needed in repo)
test-*.js
*.test.local.js

# ===== SECURITY & CERTIFICATES =====
# SSL Certificates
*.crt
*.cert
*.ca-bundle
*.p7b
*.p7s
*.spc

# SSH Keys
id_rsa
id_dsa
id_ecdsa
id_ed25519
*.pub

# ===== DOCUMENTATION DRAFTS =====
# Draft documentation (keep final versions)
DRAFT-*
draft-*
TODO.md
NOTES.md

# ===== ANALYTICS & MONITORING =====
# Error tracking
.sentry/

# Analytics
.analytics/

# ===== CUSTOM PROJECT FILES =====
# Custom ignore patterns for MovieStream
test-results/
screenshots/
videos/

# Local movie files (if any)
movies/
media/

# ===================================
# IMPORTANT NOTES:
# 
# ✅ SAFE TO COMMIT:
# - Source code files (.js, .jsx, .css, etc.)
# - Configuration files (package.json, vercel.json)
# - Documentation (.md files)
# - Public assets (images, icons)
# - Example environment files (.env.example)
# 
# ❌ NEVER COMMIT:
# - Environment files with real credentials
# - API keys or secrets
# - Database files with real data
# - Personal configuration files
# - Build outputs
# - Node modules
# 
# 🔒 SECURITY REMINDER:
# Always review files before committing!
# Use 'git status' to check what will be committed
# ===================================