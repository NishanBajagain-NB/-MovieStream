# ===================================
# MovieStream Frontend - .gitignore
# ===================================

# ===== ENVIRONMENT & SECRETS =====
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*
!.env.example

# ===== NODE.JS & NPM =====
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ===== BUILD & DISTRIBUTION =====
dist/
dist-ssr/
build/
out/

# ===== LOGS & DEBUGGING =====
*.log
logs/
*.pid
*.seed
*.pid.lock
coverage/
*.lcov

# ===== EDITOR & IDE =====
.vscode/*
!.vscode/extensions.json
.idea/
*.iml
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ===== OPERATING SYSTEM =====
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ===== TEMPORARY & CACHE =====
.tmp/
.temp/
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# ===== DEPLOYMENT =====
.vercel/
.netlify/

# ===== MISC =====
*.bak
*.backup
*.old