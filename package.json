{
  "name": "movie-streaming-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "vite",
    "build": "vite build",
    "vercel-build": "vite build",
    "deploy": "node deploy-vercel.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:prod": "npm run build && npm run preview",
    "start:prod": "node start-production.js",
    "start": "npm run dev",
    "test:setup": "node test-setup.js",
    "test:connection": "node test-backend-connection.js",
    "test:admin": "node test-admin-functionality.js",
    "test:upload": "node test-movie-upload.js"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "axios": "^1.13.6",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "swiper": "^12.1.2",
    "express": "^4.18.2",
    "mysql2": "^3.6.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^7.3.1"
  }
}
